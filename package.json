{
  "name": "leaseconnect",
  "version": "0.1.0",
  "description": "Car specification matching system for leasing companies",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:clean": "rm -rf .next && next dev --port 3001",
    "dev:fresh": "npx kill-port 3001 2>/dev/null; next dev --port 3001",
    "dev:free": "npx kill-port 3000",
    "build": "next build --no-lint",
    "start": "next start --port 3001",
    "lint": "next lint",
    "dev:api": "tsx watch src/index.ts",
    "build:api": "tsc -p tsconfig.api.json",
    "start:api": "node dist/index.js",
    "lint:api": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"docs/**/*.md\"",
    "test": "node -e \"console.log('ok')\"",
    "ingest": "tsx src/index.ts",
    "migrate": "tsx scripts/migrate.ts",
    "verify": "tsx scripts/verify.ts",
    "load-autodisk": "tsx scripts/load-autodisk.ts",
    "check-tables": "tsx scripts/check-tables.ts",
    "test-matching": "tsx scripts/test-matching.ts",
    "rematch-all": "tsx scripts/rematch-all.ts",
    "ingest-store": "tsx scripts/ingest-and-store.ts",
    "ingest-chunked": "tsx scripts/ingest-chunked.ts"
  },
  "keywords": [
    "car",
    "leasing",
    "matching",
    "specifications"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.91.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.5",
    "next": "^14.2.35",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/xlsx": "^0.0.35",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
